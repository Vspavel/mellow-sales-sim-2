PORT=3210
STORAGE_DRIVER=file

# Postgres storage
# Use either DATABASE_URL or one of the Vercel Postgres URLs below.
# STORAGE_DRIVER=postgres
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# POSTGRES_URL=postgres://user:pass@host:5432/dbname
# POSTGRES_PRISMA_URL=postgres://user:pass@host:5432/dbname
# POSTGRES_URL_NON_POOLING=postgres://user:pass@host:5432/dbname
# POSTGRES_BOOTSTRAP_FROM_FILE=true
# PG_POOL_MAX=3
# PG_CONNECT_TIMEOUT_MS=5000
# PG_IDLE_TIMEOUT_MS=10000
# POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# Optional LLM runtime
# ANTHROPIC_API_KEY=

# Optional result delivery
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=simulator@mellow.io
# RESULT_EMAIL=onboarding-simulations@mellow.io
