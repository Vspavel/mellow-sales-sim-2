# =============================================================
# Mellow Sales Simulator v2 — Environment Configuration
# =============================================================
# Copy this file to .env and fill in all required values.
# Never commit .env to version control.

# ── Telegram bot tokens ──────────────────────────────────────
# One bot per persona. Get tokens from @BotFather on Telegram.
# Each bot must be a separate bot registered with @BotFather.
# Suggested bot names: @MellowAndreyBot, @MellowAlexeyBot, etc.
BOT_TOKEN_ANDREY=
BOT_TOKEN_ALEXEY=
BOT_TOKEN_CFO_ROUND=
BOT_TOKEN_ENG_MANAGER=
BOT_TOKEN_OPS_MANAGER=
BOT_TOKEN_HEAD_FINANCE=
BOT_TOKEN_INTERNAL_LEGAL=
BOT_TOKEN_EXTERNAL_LEGAL=

# ── Email / SMTP ─────────────────────────────────────────────
# Used to send post-run transcripts and assessments.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=simulator@mellow.io
RESULT_EMAIL=onboarding-simulations@mellow.io

# ── Storage paths ────────────────────────────────────────────
# Relative to telegram-v2/ directory (or absolute paths).
SESSIONS_DIR=./data/sessions
LOGS_DIR=./data/logs
